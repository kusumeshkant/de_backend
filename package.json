{
  "name": "dq-graphql-api",
  "version": "1.0.0",
  "description": "GraphQL API for Dequeue application",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node src/seed.js",
    "build:worker": "node build-worker.mjs",
    "deploy": "node build-worker.mjs && wrangler deploy",
    "worker:dev": "node build-worker.mjs && wrangler dev --no-bundle"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "applicationinsights": "^3.14.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.7.0",
    "graphql": "^16.6.0",
    "graphql-depth-limit": "^1.1.0",
    "mongoose": "^7.0.0",
    "nodemailer": "^8.0.4",
    "razorpay": "^2.9.6",
    "resend": "^6.10.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  },
  "engines": {
    "node": "20.x"
  }
}
