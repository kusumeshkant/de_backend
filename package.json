{
  "name": "dq-graphql-api",
  "version": "1.0.0",
  "description": "GraphQL API for Dequeue application",
  "main": "index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node src/seed.js",
    "build:worker": "node build-worker.mjs",
    "deploy": "node build-worker.mjs && wrangler deploy",
    "worker:dev": "node build-worker.mjs && wrangler dev --no-bundle"
  },
  "dependencies": {
    "@apollo/server": "^4.11.0",
    "@as-integrations/cloudflare-workers": "^1.1.1",
    "@as-integrations/next": "^4.1.0",
    "dotenv": "^17.2.3",
    "firebase-admin": "^13.7.0",
    "graphql": "^16.6.0",
    "mongoose": "^7.0.0",
    "nodemailer": "^8.0.4",
    "razorpay": "^2.9.6",
    "resend": "^6.10.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "esbuild": "^0.27.7",
    "esbuild-plugin-polyfill-node": "^0.3.0",
    "nodemon": "^3.0.0",
    "wrangler": "^4.80.0"
  }
}
