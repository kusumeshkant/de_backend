# MongoDB Atlas free tier (or local: mongodb://localhost:27017/dq_app)
MONGO_URI=mongodb+srv://<db_username>:<db_password>@cluster0.xxxxx.mongodb.net/dq_app?retryWrites=true&w=majority

# Firebase Admin SDK service account JSON file path
# Download from: Firebase Console > Project Settings > Service accounts > Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

PORT=4000